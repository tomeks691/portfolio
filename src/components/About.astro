---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="about" class="py-20 px-4">
  <div class="max-w-4xl mx-auto fade-in">
    <h2 class="section-title">
      <span class="gradient-text">{t(lang, 'about.title')}</span>
    </h2>

    <div class="flex flex-col md:flex-row items-center gap-10">
      <!-- Photo placeholder -->
      <div class="flex-shrink-0">
        <div class="w-48 h-48 rounded-full bg-gradient-to-br from-indigo-500 to-cyan-500 p-1">
          <div class="w-full h-full rounded-full bg-gray-900 flex items-center justify-center text-4xl">
            👨‍💻
          </div>
        </div>
      </div>

      <div>
        <p class="text-lg text-gray-300 leading-relaxed">
          {t(lang, 'about.bio')}
        </p>
      </div>
    </div>
  </div>
</section>
